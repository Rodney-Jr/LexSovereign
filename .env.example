# nomosdesk Environment Configuration

# AI Provider Configuration
# Options: gemini (default), openai, anthropic, openrouter
AI_PROVIDER=gemini

# Google Gemini API (Primary)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter — Universal AI Gateway
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_FAST_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_SITE_URL=https://app.nomosdesk.com
OPENROUTER_SITE_NAME=NomosDesk

# OpenAI / Anthropic fallback keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Regional Statutory Public Keys (Phase 1)
# Use the jurisdiction code as a prefix (GH, NG, KE, etc.)
GH_GAZETTE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Email Configuration (Resend)
RESEND_API_KEY=re_123456789
RESEND_FROM="NomosDesk <noreply@nomosdesk.com>"
PLATFORM_URL=https://app.nomosdesk.com
VITE_STUDIO_URL=http://localhost:3006

# Core Features & UI
VITE_SHOW_PRICING=true
PORT=3001
SOVEREIGN_PIN=8899
DATABASE_URL=postgresql://user:password@localhost:5432/nomosdesk
DAS_SCRUBBING_LEVEL=2 # 1=Regex, 2=Regex+LeanLLM, 3=SemanticNER (Phase 2)
LOG_LEVEL=info
