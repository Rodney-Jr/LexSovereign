generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  passwordHash          String
  name                  String
  roleString            String                 @default("INTERNAL_COUNSEL") @map("role")
  region                String                 @default("GH_ACC_1")
  tenantId              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  attributes            Json?                  @default("{}")
  provider              String                 @default("LOCAL")
  providerId            String?
  roleId                String?
  resetToken            String?                @unique
  resetTokenExpires     DateTime?
  credentials           Json?                  @default("[]")
  jurisdictionPins      Json?                  @default("[]")
  maxWeeklyHours        Float                  @default(40.0)
  roleSeniority         Float                  @default(1.0)
  isActive              Boolean                @default(true)
  lastActiveAt          DateTime               @default(now())
  mfaEnabled            Boolean                @default(false)
  mfaSecret             String?
  mfaBackupCodes        Json?                  @default("[]")
  departmentId          String?
  aiRiskAnalyses        AIRiskAnalysis[]
  activityEntries       ActivityEntry[]
  approvals             Approval[]
  auditLogs             AuditLog[]
  collaborationMessages CollaborationMessage[]
  documentVersions      DocumentVersion[]
  assignedMatters       Matter[]
  tasks                 Task[]
  timeEntries           TimeEntry[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  role                  Role?                  @relation(fields: [roleId], references: [id])
  tenant                Tenant?                @relation(fields: [tenantId], references: [id])
  firmAssets            FirmAsset[]
  leaveRecords          LeaveRecord[]
  cleRecords            CLERecord[]
  salaryRecords         SalaryRecord[]
  appraisals            PerformanceAppraisal[] @relation("AppraisalSubject")
  authoredAppraisals    PerformanceAppraisal[] @relation("Reviewer")
}

model Role {
  id          String       @id @default(uuid())
  name        String
  description String?
  isSystem    Boolean      @default(false)
  tenantId    String?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  users       User[]
  permissions Permission[] @relation("PermissionToRole")
  policies    Policy[]     @relation("PolicyToRole")

  @@unique([name, tenantId])
}

model Permission {
  id          String @id
  description String
  resource    String
  action      String
  roles       Role[] @relation("PermissionToRole")
}

model Policy {
  id          String   @id @default(uuid())
  name        String
  description String?
  effect      String   @default("DENY")
  resource    String
  action      String
  condition   String?
  priority    Int      @default(0)
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  roles       Role[]   @relation("PolicyToRole")
}

model Tenant {
  id                   String             @id @default(uuid())
  name                 String
  plan                 String             @default("STANDARD")
  primaryRegion        String             @default("GH_ACC_1")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  appMode              String             @default("LAW_FIRM")
  encryptionMode       String             @default("SYSTEM_MANAGED")
  status               String             @default("ACTIVE")
  separationMode       String             @default("OPEN")
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  subscriptionStatus   String?
  trialExpiresAt       DateTime?
  aiCreditLimit        Float              @default(20.0)
  isTrial              Boolean            @default(false)
  enabledModules       String[]           @default(["CORE"])
  attributes           Json?              @default("{}")
  lastStorageSyncedAt  DateTime?
  aiUsages             AIUsage[]
  brandingProfiles     BrandingProfile[]
  bridges              Bridge[]
  chatbotConfig        ChatbotConfig?
  departments          Department[]
  documentTemplates    DocumentTemplate[]
  invitations          Invitation[]
  matters              Matter[]
  matterTypes          MatterType[]
  policies             Policy[]
  roles                Role[]
  users                User[]
  workflows            Workflow[]
  firmAssets           FirmAsset[]
  expenses             Expense[]
  leaveRecords         LeaveRecord[]
  candidates           Candidate[]
  cleRecords           CLERecord[]
  onboardingItems      OnboardingItem[]
  salaryRecords        SalaryRecord[]
  appraisals           PerformanceAppraisal[]
  accounts             FirmAccount[]
  ledgerTransactions   LedgerTransaction[]
  bankTransactions     BankTransaction[]
  externalMappings     ExternalMapping[]
  syncLogs             SyncLog[]
}

model ChatbotConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  botName           String
  welcomeMessage    String
  isEnabled         Boolean  @default(true)
  channels          Json
  knowledgeBaseIds  Json
  systemInstruction String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
}

model Matter {
  id                    String                 @id @default(uuid())
  name                  String
  client                String
  type                  String
  status                String                 @default("OPEN")
  riskLevel             String                 @default("LOW")
  description           String?
  tenantId              String
  internalCounselId     String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  attributes            Json?                  @default("{}")
  complexityWeight      Float                  @default(5.0)
  departmentId          String?
  matterTypeId          String?
  workflowStateId       String?
  aiRiskAnalyses        AIRiskAnalysis[]
  aiUsages              AIUsage[]
  activityTimeline      ActivityEntry[]
  approvals             Approval[]
  auditLogs             AuditLog[]
  billingComponents     BillingComponent[]
  caseMetadata          CaseMetadata?
  collaborationMessages CollaborationMessage[]
  contractMetadata      ContractMetadata?
  deadlines             Deadline[]
  documents             Document[]
  evidenceLinks         EvidenceLink[]
  hearings              Hearing[]
  invoices              Invoice[]
  department            Department?            @relation(fields: [departmentId], references: [id])
  internalCounsel       User?                   @relation(fields: [internalCounselId], references: [id])
  matterType            MatterType?            @relation(fields: [matterTypeId], references: [id])
  tenant                Tenant                 @relation(fields: [tenantId], references: [id])
  workflowState         WorkflowState?         @relation(fields: [workflowStateId], references: [id])
  risks                 PredictiveRisk[]
  tasks                 Task[]
  timeEntries           TimeEntry[]
}

model MatterType {
  id                String     @id @default(uuid())
  name              String
  description       String?
  category          String
  defaultWorkflowId String?
  tenantId          String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  matters           Matter[]
  defaultWorkflow   Workflow?  @relation("DefaultWorkflow", fields: [defaultWorkflowId], references: [id])
  tenant            Tenant     @relation(fields: [tenantId], references: [id])
  workflows         Workflow[] @relation("MatterTypeWorkflows")
}

model Workflow {
  id           String          @id @default(uuid())
  name         String
  description  String?
  matterTypeId String
  tenantId     String
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  defaultFor   MatterType[]    @relation("DefaultWorkflow")
  matterType   MatterType      @relation("MatterTypeWorkflows", fields: [matterTypeId], references: [id])
  tenant       Tenant          @relation(fields: [tenantId], references: [id])
  states       WorkflowState[]
}

model WorkflowState {
  id                  String               @id @default(uuid())
  name                String
  description         String?
  order               Int
  workflowId          String
  canAssignTasks      Boolean              @default(true)
  isApprovalRequired  Boolean              @default(false)
  isInitial           Boolean              @default(false)
  isFinal             Boolean              @default(false)
  color               String?
  approvals           Approval[]
  matters             Matter[]
  tasks               Task[]
  workflow            Workflow             @relation(fields: [workflowId], references: [id])
  outgoingTransitions WorkflowTransition[] @relation("FromState")
  incomingTransitions WorkflowTransition[] @relation("ToState")
}

model WorkflowTransition {
  id           String        @id @default(uuid())
  fromStateId  String
  toStateId    String
  requiredRole String?
  condition    String?
  fromState    WorkflowState @relation("FromState", fields: [fromStateId], references: [id])
  toState      WorkflowState @relation("ToState", fields: [toStateId], references: [id])
}

model Task {
  id              String         @id @default(uuid())
  title           String
  description     String?
  status          String         @default("PENDING")
  priority        String         @default("MEDIUM")
  dueDate         DateTime?
  assigneeId      String?
  matterId        String
  workflowStateId String?
  isAutoGenerated Boolean        @default(false)
  tenantId        String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  assignee        User?          @relation(fields: [assigneeId], references: [id])
  matter          Matter         @relation(fields: [matterId], references: [id])
  workflowState   WorkflowState? @relation(fields: [workflowStateId], references: [id])
}

model ContractMetadata {
  id               String    @id @default(uuid())
  matterId         String    @unique
  tenantId         String
  contractValue    Float?
  currency         String    @default("USD")
  counterpartyName String?
  effectiveDate    DateTime?
  renewalDate      DateTime?
  expiryDate       DateTime?
  alertTriggered   Boolean   @default(false)
  matter           Matter    @relation(fields: [matterId], references: [id])
}

model CaseMetadata {
  id           String    @id @default(uuid())
  matterId     String    @unique
  tenantId     String
  jurisdiction String?
  caseNumber   String?
  courtName    String?
  judgeName    String?
  filedDate    DateTime?
  matter       Matter    @relation(fields: [matterId], references: [id])
}

model Deadline {
  id             String   @id @default(uuid())
  matterId       String
  tenantId       String
  title          String
  dueDate        DateTime
  description    String?
  status         String   @default("PENDING")
  priority       String   @default("MEDIUM")
  isReminderSent Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  matter         Matter   @relation(fields: [matterId], references: [id])
}

model Hearing {
  id          String   @id @default(uuid())
  matterId    String
  tenantId    String
  hearingDate DateTime
  location    String?
  judgeName   String?
  purpose     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  matter      Matter   @relation(fields: [matterId], references: [id])
}

model EvidenceLink {
  id            String   @id @default(uuid())
  matterId      String
  tenantId      String
  documentId    String
  exhibitNumber String?
  description   String?
  profferedBy   String?
  createdAt     DateTime @default(now())
  document      Document @relation(fields: [documentId], references: [id])
  matter        Matter   @relation(fields: [matterId], references: [id])
}

model AIRiskAnalysis {
  id                String   @id @default(uuid())
  matterId          String
  tenantId          String
  riskScore         Float    @default(0.0)
  summary           String?
  identifiedClauses Json?    @default("[]")
  confidenceScore   Float    @default(0.0)
  isValidated       Boolean  @default(false)
  validatorId       String?
  createdAt         DateTime @default(now())
  matter            Matter   @relation(fields: [matterId], references: [id])
  validator         User?    @relation(fields: [validatorId], references: [id])
}

model ActivityEntry {
  id        String   @id @default(uuid())
  matterId  String
  tenantId  String
  type      String
  actorId   String?
  details   String
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now())
  actor     User?    @relation(fields: [actorId], references: [id])
  matter    Matter   @relation(fields: [matterId], references: [id])
}

model Department {
  id          String   @id @default(uuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  matters     Matter[]
  users       User[]
}

model Document {
  id              String            @id @default(uuid())
  name            String
  uri             String
  jurisdiction    String
  privilege       String            @default("INTERNAL")
  classification  String            @default("Confidential")
  matterId        String
  tenantId        String
  lastReviewed    DateTime          @default(now())
  createdAt       DateTime          @default(now())
  attributes      Json?             @default("{}")
  encryptionKeyId String?
  isEncrypted     Boolean           @default(false)
  encryptionIV    String?
  updatedAt       DateTime          @default(now()) @updatedAt
  status          String            @default("AI_DRAFTED")
  description     String?
  fileSize        BigInt            @default(0)
  matter          Matter            @relation(fields: [matterId], references: [id])
  versions        DocumentVersion[]
  evidenceLinks   EvidenceLink[]
}

model DocumentVersion {
  id            String   @id @default(uuid())
  documentId    String
  tenantId      String
  versionNumber Int
  uri           String
  authorId      String?
  changeSummary String?
  isCurrent     Boolean  @default(false)
  createdAt     DateTime @default(now())
  author        User?    @relation(fields: [authorId], references: [id])
  document      Document @relation(fields: [documentId], references: [id])
}

model Approval {
  id              String        @id @default(uuid())
  matterId        String
  tenantId        String
  workflowStateId String
  userId          String
  status          String        @default("APPROVED")
  comments        String?
  createdAt       DateTime      @default(now())
  matter          Matter        @relation(fields: [matterId], references: [id])
  user            User          @relation(fields: [userId], references: [id])
  workflowState   WorkflowState @relation(fields: [workflowStateId], references: [id])
}

model TimeEntry {
  id              String   @id @default(uuid())
  description     String
  durationMinutes Int
  startTime       DateTime
  isBillable      Boolean  @default(true)
  status          String   @default("Draft")
  matterId        String
  tenantId        String
  userId          String
  matter          Matter   @relation(fields: [matterId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model PredictiveRisk {
  id             String  @id @default(uuid())
  type           String
  probability    Float
  impact         String
  description    String
  matterId       String
  tenantId       String
  mitigationPlan String?
  riskCategory   String  @default("OPERATIONAL")
  status         String  @default("IDENTIFIED")
  matter         Matter  @relation(fields: [matterId], references: [id])
}

model CollaborationMessage {
  id             String   @id @default(uuid())
  text           String
  authorId       String
  matterId       String
  tenantId       String
  attachmentUrl  String?
  attachmentName String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())
  author         User     @relation(fields: [authorId], references: [id])
  matter         Matter   @relation(fields: [matterId], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  timestamp  DateTime @default(now())
  userId     String?
  tenantId   String?
  details    String?
  ipAddress  String?
  resourceId String?
  metadata   Json?    @default("{}")
  matterId   String?
  matter     Matter?  @relation(fields: [matterId], references: [id])
  user       User?    @relation(fields: [userId], references: [id])
}

model KnowledgeArtifact {
  id          String   @id @default(uuid())
  title       String
  content     String
  category    String
  sourceUri   String
  lastIndexed DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invitation {
  id        String   @id @default(uuid())
  token     String   @unique
  email     String
  roleName  String
  tenantId  String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model DocumentTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String
  category     String
  jurisdiction String
  content      String
  version      String   @default("1.0.0")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  structure    Json
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])

  @@unique([name, tenantId])
}

model RegulatoryRule {
  id              String   @id @default(uuid())
  name            String
  authority       String
  triggerKeywords String[]
  blockThreshold  Float
  description     String
  isActive        Boolean  @default(true)
  region          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PricingConfig {
  id                   String   @id
  basePrice            Float
  pricePerUser         Float
  creditsIncluded      Int      @default(0)
  features             Json
  updatedAt            DateTime @updatedAt
  maxUsers             Int      @default(5)
  stripeBasePriceId         String?
  stripeUserPriceId         String?
  stripeAiPriceId           String?
  stripeStoragePriceId      String?
  stripeAccountingPriceId   String?
  stripeHrEnterprisePriceId String?
}

model BrandingProfile {
  id               String   @id @default(uuid())
  name             String
  logoUrl          String?
  primaryFont      String   @default("Times New Roman")
  headerText       String?
  footerText       String?
  coverPageEnabled Boolean  @default(false)
  watermarkText    String?
  version          Int      @default(1)
  tenantId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  primaryColor     String   @default("#4F46E5")
  secondaryColor   String   @default("#6366F1")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
}

model Lead {
  id        String   @id @default(uuid())
  email     String
  name      String
  company   String?
  status    String   @default("NEW")
  source    String   @default("WEB_MODAL")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  phone     String?
}

model GazetteEmbedding {
  id           String   @id @default(uuid())
  region       String
  title        String
  contentChunk String
  embedding    Json?
  sourceUrl    String?
  metadata     Json?    @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([region])
}

model DailyFxRate {
  id            String   @id @default(uuid())
  currencyPair  String
  rate          Float
  provider      String   @default("EXCHANGERATE_API")
  effectiveDate DateTime
  capturedAt    DateTime @default(now())

  @@unique([currencyPair, effectiveDate])
}

model ChatConversation {
  id           String   @id @default(uuid())
  sessionId    String
  visitorEmail String?
  visitorName  String?
  messages     Json
  source       String   @default("MARKETING_WIDGET")
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  intentScore  Float    @default(0.0)
  isLead       Boolean  @default(false)
  metadata     Json?

  @@index([sessionId])
  @@index([createdAt])
  @@index([isLead])
}

model Bridge {
  id            String   @id @default(uuid())
  name          String
  category      String
  provider      String
  status        String   @default("Nominal")
  encapsulation String
  priority      String   @default("P0")
  lastActivity  String?
  tenantId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
}

model BillingComponent {
  id              String               @id @default(uuid())
  matterId        String
  type            BillingComponentType
  isActive        Boolean              @default(true)
  priority        Int                  @default(0)
  fixedAmount     Float?
  paymentSchedule Json?
  depositRequired Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  matter          Matter               @relation(fields: [matterId], references: [id])
  lineItems       InvoiceLineItem[]
}

model Invoice {
  id          String            @id @default(uuid())
  matterId    String
  tenantId    String
  status      InvoiceStatus     @default(DRAFT)
  totalAmount Float             @default(0.0)
  issuedAt    DateTime?
  dueDate     DateTime?
  paidAt      DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  aiUsages    AIUsage[]
  matter      Matter            @relation(fields: [matterId], references: [id])
  lineItems   InvoiceLineItem[]
}

model InvoiceLineItem {
  id                 String            @id @default(uuid())
  invoiceId          String
  billingComponentId String?
  amount             Float
  description        String
  billingComponent   BillingComponent? @relation(fields: [billingComponentId], references: [id])
  invoice            Invoice           @relation(fields: [invoiceId], references: [id])
}

model AIUsage {
  id               String    @id @default(uuid())
  tenantId         String
  matterId         String?
  modelId          String
  promptTokens     Int       @default(0)
  completionTokens Int       @default(0)
  totalTokens      Int       @default(0)
  costCredits      Float     @default(0.0)
  stripeSyncedAt   DateTime?
  createdAt        DateTime  @default(now())
  invoiceId        String?
  invoice          Invoice?  @relation(fields: [invoiceId], references: [id])
  matter           Matter?   @relation(fields: [matterId], references: [id])
  tenant           Tenant    @relation(fields: [tenantId], references: [id])
}

enum BillingComponentType {
  HOURLY
  FLAT_FEE
  MILESTONE
  CONTINGENCY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOIDED
  OVERDUE
}

model FirmAsset {
  id           String    @id @default(uuid())
  tenantId     String
  name         String
  serialNumber String    @unique
  category     String
  status       String
  assignedToId String?
  purchaseDate DateTime
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
}

model Expense {
  id          String   @id @default(uuid())
  tenantId    String
  description String
  amount      Float
  category    String
  status      String
  expenseDate DateTime
  notes       String?
  type        String   @default("UTILITY") // UTILITY or PETTY_CASH
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model LeaveRecord {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  type      String
  startDate DateTime
  endDate   DateTime
  status    String   @default("Pending")
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Candidate {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String
  role      String
  status    String   @default("Applied")
  appliedOn DateTime @default(now())
  
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model CLERecord {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  course    String
  credits   Int
  date      DateTime
  deadline  DateTime?
  
  user      User     @relation(fields: [userId], references: [id])
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model OnboardingItem {
  id          String   @id @default(uuid())
  tenantId    String
  task        String
  isCompleted Boolean  @default(false)
  role        String?
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model SalaryRecord {
  id              String   @id @default(uuid())
  userId          String
  tenantId        String
  baseSalary      Float
  currency        String   @default("GHS")
  bankAccount     String?
  effectiveFrom   DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
}

model PerformanceAppraisal {
  id          String   @id @default(uuid())
  userId      String
  tenantId    String
  date        DateTime @default(now())
  rating      String
  reviewerId  String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("AppraisalSubject", fields: [userId], references: [id])
  reviewer    User     @relation("Reviewer", fields: [reviewerId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model FirmAccount {
  id          String        @id @default(uuid())
  name        String
  type        String        // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  category    String?       // BANK, ACCOUNTS_RECEIVABLE, TRUST, etc.
  balance     Float         @default(0)
  currency    String        @default("GHS")
  tenantId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  entries     LedgerEntry[]

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
}

model LedgerTransaction {
  id          String        @id @default(uuid())
  date        DateTime      @default(now())
  description String
  reference   String?       // Invoice ID, Cheque Number, etc.
  status      String        @default("POSTED") // POSTED, VOID, PENDING
  tenantId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  entries     LedgerEntry[]

  tenant      Tenant        @relation(fields: [tenantId], references: [id])
}

model LedgerEntry {
  id            String            @id @default(uuid())
  transactionId String
  accountId     String
  debit         Float             @default(0)
  credit        Float             @default(0)
  description   String?
  reconciled    Boolean           @default(false)
  createdAt     DateTime          @default(now())

  transaction   LedgerTransaction @relation(fields: [transactionId], references: [id])
  account       FirmAccount       @relation(fields: [accountId], references: [id])
}

model BankTransaction {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  amount      Float
  type        String   // DEBIT, CREDIT
  externalId  String?  @unique
  bankAccount String?
  tenantId    String
  status      String   @default("PENDING") // PENDING, MATCHED, IGNORED
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model ExternalMapping {
  id          String   @id @default(uuid())
  tenantId    String
  system      String   // QUICKBOOKS, LAWPAY
  localType   String   // ACCOUNT, MATTER, USER
  localId     String
  externalId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, system, localType, localId])
}

model SyncLog {
  id          String   @id @default(uuid())
  tenantId    String
  system      String
  status      String   // SUCCESS, FAILED
  message     String?
  timestamp   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model SupportAccessGrant {
  id              String   @id @default(uuid())
  tenantId        String
  grantedByUserId String
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  isActive        Boolean  @default(true)
}
